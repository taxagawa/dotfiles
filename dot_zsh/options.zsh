# Shell options
setopt auto_pushd            # Automatically push directories onto the stack on cd
setopt pushd_ignore_dups     # Don't push duplicate directories
setopt pushd_silent          # Suppress output when pushing directories
setopt correct               # Suggest corrections for mistyped commands
setopt nobeep                # Disable terminal bell
setopt auto_cd               # cd by typing directory name alone
setopt interactive_comments  # Allow comments in interactive shell
