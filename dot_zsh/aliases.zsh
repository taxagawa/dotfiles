# Aliases

# Git
alias g='git'

# Neovim
alias v='nvim'
alias vi='nvim'
alias vim='nvim'

# Chezmoi
alias cz='chezmoi'
alias czd='chezmoi diff'
alias cza='chezmoi apply'

# Navigation
alias ..='cd ..'
alias ...='cd ../..'

# Safety nets (prompt before overwrite/delete)
alias cp='cp -i'
alias mv='mv -i'
alias rm='rm -i'

# ls (eza)
alias ls='eza'
alias ll='eza -lh'
alias la='eza -a'
alias lla='eza -lah'
alias lt='eza --tree'
