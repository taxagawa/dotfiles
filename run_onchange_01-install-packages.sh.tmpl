#!/bin/bash
# Brewfile hash: {{ include ".chezmoitemplates/Brewfile" | sha256sum }}
# personal: {{ .personal }}
# Re-runs when Brewfile or personal flag changes (chezmoi run_onchange)
set -euo pipefail

# Install Homebrew if not present
if ! command -v brew &>/dev/null; then
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

# Render Brewfile with chezmoi template variables (personal flag controls app selection)
cat > /tmp/chezmoi-Brewfile <<'BREWFILE'
{{ template "Brewfile" . }}
BREWFILE
brew bundle --file=/tmp/chezmoi-Brewfile || true
rm -f /tmp/chezmoi-Brewfile
